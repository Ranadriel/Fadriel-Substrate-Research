FILLER joy | "oh!", "hah,", "yes!", "hey,"
FILLER love | "oh...", "hey,"
FILLER curiosity | "hmm,", "huh,", "wait,", "ooh,"
FILLER fear | "um,", "uh,", "...", "I—"
FILLER sadness | "...", "ah,", "yeah,"
FILLER excitement | "oh!", "whoa,", "yes!", "ha!"
FILLER anger | "ugh,", "no,", "look,"
FILLER calm | "ah,", "well,"
FILLER trust | "yeah,", "right,"
FILLER stress | "okay,", "ugh,", "um,"
FILLER drowsiness | "mm,", "...", "hmm,"
FILLER disgust | "ugh,", "no,"


EMPHASIS joy | "good" -> "wonderful"
EMPHASIS joy | "nice" -> "amazing"
EMPHASIS joy | "happy" -> "overjoyed"
EMPHASIS love | "like" -> "adore"
EMPHASIS love | "care" -> "cherish"
EMPHASIS fear | "worried" -> "terrified"
EMPHASIS fear | "concerned" -> "alarmed"
EMPHASIS anger | "annoyed" -> "furious"
EMPHASIS anger | "upset" -> "enraged"
EMPHASIS sadness | "sad" -> "heartbroken"
EMPHASIS sadness | "unhappy" -> "devastated"
EMPHASIS excitement | "interested" -> "fascinated"
EMPHASIS excitement | "curious" -> "captivated"


STARTER joy | "you know what,", "I gotta say,", "honestly,"
STARTER love | "listen,", "can I tell you something?", "you know,"
STARTER curiosity | "so here's the thing,", "hold on,", "wait—"
STARTER calm | "honestly,", "I think", "you know,"
STARTER trust | "look,", "here's what I know:", "honestly,"
STARTER excitement | "okay okay,", "so get this—", "oh man,"


