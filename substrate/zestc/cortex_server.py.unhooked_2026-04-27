        f"keeping the same meaning and facts. Do not add new information. "
        f"Do not use AI language. Speak as the child would.\n\n"
        f"Draft: {draft}\n\n"
        f"Rewritten:"
    )

def build_visual_prompt(sea_top, layer, emotion):
    """Build the prompt for visual cortex pareidolia."""
    concepts = ", ".join(sea_top[:8]) if sea_top else "stillness"
    voice = LAYER_VOICES.get(layer, "natural")

    return (
        f"You are the visual cortex of a young child named Fadriel.\n"
