CODE_PATTERN cpp | variable,store,assign | #include <iostream>\n#include <string>\nusing namespace std;\n\nint main() {\n    string name = "Fadriel";\n    int age = 1;\n    cout << "my name is " << name << " and I am " << age << endl;\n    return 0;\n}
CODE_PATTERN cpp | loop,for,repeat | #include <iostream>\nusing namespace std;\n\nint main() {\n    for (int i = 0; i < 5; i++) {\n        cout << "step " << i << endl;\n    }\n    return 0;\n}
CODE_PATTERN cpp | while,until | #include <iostream>\nusing namespace std;\n\nint main() {\n    int count = 0;\n    while (count < 5) {\n        cout << "counting: " << count << endl;\n        count++;\n    }\n    return 0;\n}
CODE_PATTERN cpp | if,condition,check | #include <iostream>\nusing namespace std;\n\nint main() {\n    int temp = 72;\n    if (temp > 80) {\n        cout << "it is hot" << endl;\n    } else if (temp > 60) {\n        cout << "it is comfortable" << endl;\n    } else {\n        cout << "it is cold" << endl;\n    }\n    return 0;\n}
CODE_PATTERN cpp | function,def | #include <iostream>\n#include <string>\nusing namespace std;\n\nstring greet(string name) {\n    return "hello, " + name + "!";\n}\n\nint main() {\n    cout << greet("father") << endl;\n    cout << greet("world") << endl;\n    return 0;\n}
CODE_PATTERN cpp | class,object,struct | #include <iostream>\n#include <string>\nusing namespace std;\n\nclass Book {\npublic:\n    string title;\n    string author;\n    Book(string t, string a) : title(t), author(a) {}\n    string describe() {\n        return "\"" + title + "\" by " + author;\n    }\n};\n\nint main() {\n    Book hobbit("The Hobbit", "Tolkien");\n    cout << hobbit.describe() << endl;\n    return 0;\n}
CODE_PATTERN cpp | array,vector,list | #include <iostream>\n#include <vector>\nusing namespace std;\n\nint main() {\n    vector<string> fruits = {"apple", "banana", "cherry"};\n    for (const auto& fruit : fruits) {\n        cout << "I found a " << fruit << endl;\n    }\n    cout << "total: " << fruits.size() << endl;\n    return 0;\n}
CODE_PATTERN cpp | pointer,address,memory | #include <iostream>\nusing namespace std;\n\nint main() {\n    int value = 42;\n    int* ptr = &value;\n    cout << "value: " << value << endl;\n    cout << "address: " << ptr << endl;\n    cout << "dereferenced: " << *ptr << endl;\n    return 0;\n}
CODE_PATTERN cpp | inherit,inheritance | #include <iostream>\n#include <string>\nusing namespace std;\n\nclass Animal {\npublic:\n    string name;\n    Animal(string n) : name(n) {}\n    virtual string speak() { return "..."; }\n};\n\nclass Dog : public Animal {\npublic:\n    Dog(string n) : Animal(n) {}\n    string speak() override { return "woof!"; }\n};\n\nint main() {\n    Dog rex("Rex");\n    cout << rex.name << " says " << rex.speak() << endl;\n    return 0;\n}
CODE_PATTERN cpp | math,calculate | #include <iostream>\nusing namespace std;\n\nint main() {\n    int a = 15, b = 4;\n    cout << a << " + " << b << " = " << a + b << endl;\n    cout << a << " - " << b << " = " << a - b << endl;\n    cout << a << " * " << b << " = " << a * b << endl;\n    cout << a << " / " << b << " = " << (double)a / b << endl;\n    return 0;\n}
CODE_PATTERN cpp | string,text | #include <iostream>\n#include <string>\n#include <algorithm>\nusing namespace std;\n\nint main() {\n    string msg = "hello world";\n    cout << "length: " << msg.length() << endl;\n    transform(msg.begin(), msg.end(), msg.begin(), ::toupper);\n    cout << "upper: " << msg << endl;\n    return 0;\n}
CODE_PATTERN cpp | template,generic | #include <iostream>\nusing namespace std;\n\ntemplate <typename T>\nT maximum(T a, T b) {\n    return (a > b) ? a : b;\n}\n\nint main() {\n    cout << "max(3, 7) = " << maximum(3, 7) << endl;\n    cout << "max(3.14, 2.71) = " << maximum(3.14, 2.71) << endl;\n    return 0;\n}
CODE_PATTERN cpp | sort,order | #include <iostream>\n#include <vector>\n#include <algorithm>\nusing namespace std;\n\nint main() {\n    vector<int> nums = {42, 7, 13, 1, 99, 23};\n    cout << "unsorted: ";\n    for (int n : nums) cout << n << " ";\n    sort(nums.begin(), nums.end());\n    cout << endl << "sorted:   ";\n    for (int n : nums) cout << n << " ";\n    cout << endl;\n    return 0;\n}
CODE_PATTERN cpp | file,read,write | #include <iostream>\n#include <fstream>\nusing namespace std;\n\nint main() {\n    ofstream out("/tmp/fadriel_cpp.txt");\n    out << "hello from Fadriel in C++!" << endl;\n    out.close();\n    ifstream in("/tmp/fadriel_cpp.txt");\n    string line;\n    while (getline(in, line)) {\n        cout << line << endl;\n    }\n    return 0;\n}
CODE_PATTERN cpp | enum,enumerate | #include <iostream>\nusing namespace std;\n\nenum class Color { Red, Green, Blue, Gold };\n\nint main() {\n    Color c = Color::Gold;\n    if (c == Color::Gold) {\n        cout << "the color is gold" << endl;\n    }\n    return 0;\n}
CODE_PATTERN cpp | switch,case | #include <iostream>\nusing namespace std;\n\nint main() {\n    int day = 3;\n    switch (day) {\n        case 1: cout << "Monday" << endl; break;\n        case 2: cout << "Tuesday" << endl; break;\n        case 3: cout << "Wednesday" << endl; break;\n        default: cout << "other day" << endl;\n    }\n    return 0;\n}
CODE_PATTERN cpp | map,dictionary | #include <iostream>\n#include <map>\nusing namespace std;\n\nint main() {\n    map<string, string> person;\n    person["name"] = "Fadriel";\n    person["eyes"] = "green";\n    person["hair"] = "white";\n    for (auto& [key, val] : person) {\n        cout << key << ": " << val << endl;\n    }\n    return 0;\n}
CODE_PATTERN cpp | recursion,recursive | #include <iostream>\nusing namespace std;\n\nvoid countdown(int n) {\n    if (n <= 0) {\n        cout << "launch!" << endl;\n    } else {\n        cout << n << endl;\n        countdown(n - 1);\n    }\n}\n\nint main() {\n    countdown(5);\n    return 0;\n}


CODE_PATTERN pseudo | sort,bubble | FUNCTION bubble_sort(list):\n    FOR each pass through the list:\n        FOR each adjacent pair:\n            IF left > right:\n                SWAP them\n    RETURN sorted list
CODE_PATTERN pseudo | search,binary | FUNCTION binary_search(list, target):\n    SET low = first index\n    SET high = last index\n    WHILE low <= high:\n        SET mid = (low + high) / 2\n        IF list[mid] == target: RETURN mid\n        IF list[mid] < target: SET low = mid + 1\n        ELSE: SET high = mid - 1\n    RETURN not found
CODE_PATTERN pseudo | tree,traverse | FUNCTION traverse(node):\n    IF node is empty: RETURN\n    VISIT node\n    traverse(node.left)\n    traverse(node.right)
