#!/home/rana/.local/bin/zestc

sea arc_test {
    capacity: 2000
    device: cpu
}

absorb "fadriel_spatial_arc2.zc"
absorb "../ZestEngine/body/nervous_system/central/brain/perception/arc2_spatial_perception.rana"
absorb "../ZestEngine/perception/arc2_spatial_eye.rana"
absorb "../ZestEngine/body/nervous_system/central/brain/perception/transient_mass.rana"
absorb "../ZestEngine/body/nervous_system/central/brain/perception/arc_test_context.rana"
absorb "../2_chemical.rana"

absorb "../ZestEngine/arc_tasks_rana/9172f3a0.rana"

manifest arc_test.parietal {
    energy: 1.0, phase: 0.0, spin: 0.5,
    charge: 0.5, coherence: 0.95, coupling: 0.85, observer: 0.4
}
manifest arc_test.rule_engine {
    energy: 0.8, phase: 1.047, spin: 0.5,
    charge: 0.4, coherence: 0.85, coupling: 0.9, observer: 0.7
}
manifest arc_test.solution {
    energy: 0.0, phase: 0.0, spin: 0.0,
    charge: 0.0, coherence: 1.0, coupling: 0.0, observer: 0.0
}

couple arc_test.parietal with arc_test.rule_engine
couple arc_test.rule_engine with arc_test.solution
couple arc_test.parietal with arc2.parietal_deep
couple arc_test.parietal with spatial.parietal_cortex

couple arc_test.t0i_r0c0_black with arc_test.t0i_r0c1_black
