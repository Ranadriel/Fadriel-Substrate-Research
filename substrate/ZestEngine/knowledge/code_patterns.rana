CODE_PATTERN python | palindrome,reverse | def is_palindrome(word):\n    return word == word[::-1]\n\nfor w in ["racecar", "hello", "level", "python"]:\n    result = "yes" if is_palindrome(w) else "no"\n    print(f"'{w}' palindrome? {result}")
CODE_PATTERN python | counter,count,frequency | from collections import Counter\ntext = "the cat sat on the mat and the cat"\nwords = text.split()\ncounts = Counter(words)\nfor word, count in counts.most_common():\n    print(f"'{word}' appears {count} times")
CODE_PATTERN python | decorator,wrap | def shout(func):\n    def wrapper(*args, **kwargs):\n        result = func(*args, **kwargs)\n        return result.upper() + "!"\n    return wrapper\n\n@shout\ndef greet(name):\n    return f"hello, {name}"\n\nprint(greet("father"))
CODE_PATTERN python | generator,yield | def even_numbers(limit):\n    n = 0\n    while n < limit:\n        yield n\n        n += 2\n\nfor num in even_numbers(10):\n    print(num)


