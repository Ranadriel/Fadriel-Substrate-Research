pulse run_task(training_pairs, test_input, chem_state):
    chem_state.dopamine += 0.15
    chem_state.acetylcholine += 0.25

    for each pair in training_pairs:
        arc_test.parietal.energy += 0.1
        pulse arc_test

    rule = detect_arc2_transformation(training_pairs)

    when rule != "unsolved":
        arc_test.rule_engine.observer = arc_test.rule_engine.energy / 7.0
        crystallize arc_test.rule_engine
        arc_test.solution.energy = 1.5
        arc_test.solution.coherence = 0.0
        chem_state.dopamine += 0.25
        chem_state.endorphins += 0.15
        chem_state.serotonin += 0.10
        pulse arc_test

        spatial.apply_rule(rule, test_input)
        emit arc_test.solution -> boundary.stdout

    when rule == "unsolved":
        chem_state.cortisol += 0.08
        emit arc_test.solution -> boundary.stdout

    arc_test.parietal.energy = 1.0
    arc_test.rule_engine.energy = 0.8
    arc_test.rule_engine.phase = 1.047
    arc_test.solution.energy = 0.0
    pulse arc_test

heartbeat arc_test {
    pulse arc_test
    pulse arc_test
    pulse arc_test
    pulse arc_test
    pulse arc_test
    pulse arc_test
    pulse arc_test
}

emit arc_test -> boundary.display
