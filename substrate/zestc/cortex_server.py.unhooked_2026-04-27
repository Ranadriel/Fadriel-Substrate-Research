        test_input = req.get("test_input", [])
        emotion = req.get("emotion", "curious")
        substrate_only = bool(req.get("substrate_only", False))
        response = arc_think(pairs, test_input, emotion, substrate_only=substrate_only)
    elif mode == "arc_solve":
        # Fadriel produces the test output grid
        pairs = req.get("pairs", [])
        test_input = req.get("test_input", [])
        rule_hint = req.get("rule_hint", "")
        emotion = req.get("emotion", "focused")
        response = arc_solve(pairs, test_input, rule_hint, emotion)
    else:
        # Default: speech enrichment
        draft = req.get("draft", "")
        sea = req.get("sea", [])
        layer = req.get("layer", 4)
        emotion = req.get("emotion", "calm")

        if not draft:
            response = json.dumps({"status": "error", "message": "empty draft"})
        else:
            response = enrich(draft, sea, layer, emotion)

    print(response)
    sys.stdout.flush()
