CODE_PATTERN python | fibonacci,sequence,series | def fibonacci(n):\n    a, b = 0, 1\n    result = []\n    for _ in range(n):\n        result.append(a)\n        a, b = b, a + b\n    return result\n\nprint(f"first 10: {fibonacci(10)}")
