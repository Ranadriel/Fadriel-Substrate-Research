# ═══ SLOP GATE ═══
# Reject known LLM artifact patterns that betray machine origin
SLOP_PATTERNS = [
    "as an ai",
    "as a language model",
    "i'd be happy to",
    "certainly!",
    "absolutely!",
    "great question",
    "that's a great",
    "i don't have personal",
    "i cannot",
    "i'm not able to",
    "let me help you",
    "i appreciate",
    "it's important to note",
    "it's worth noting",
]

def is_slop(text):
    """Check if the LLM output contains machine artifact patterns."""
    lower = text.lower()
    for pattern in SLOP_PATTERNS:
        if pattern in lower:
            return True
    return False

